rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{document} {
      allow read, write: if true;
    }
    match /contacts/{document} {
      allow read, write: if true;
    }
    match /campagnes/{document} {
      allow read, write: if true;
    }
    match /envois_log/{document} {
      allow read, write: if true;
    }
  }
}
